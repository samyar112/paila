{
  "name": "paila",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "APP_ENV=development expo start",
    "start:prod": "APP_ENV=production expo start",
    "android": "APP_ENV=development expo run:android",
    "android:prod": "APP_ENV=production expo run:android",
    "ios": "APP_ENV=development expo run:ios",
    "ios:prod": "APP_ENV=production expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "test:rules": "jest --runTestsByPath tests/firestore.rules.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p functions/tsconfig.json",
    "web": "expo start --web",
    "prebuild": "APP_ENV=development expo prebuild",
    "prebuild:prod": "APP_ENV=production expo prebuild",
    "sync:firebase": "bash ./scripts/sync-firebase-config.sh"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.4.0",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/app-check": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/firestore": "^23.8.8",
    "@react-native-firebase/functions": "^23.8.8",
    "@react-native-google-signin/google-signin": "^13.1.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~55.0.5",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-sensors": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-tracking-transparency": "~55.0.8",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "prop-types": "^15.8.1",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-google-mobile-ads": "^16.2.3",
    "react-native-health": "^1.18.0",
    "react-native-health-connect": "^3.2.0",

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function routeDoc(routeId) {
      return get(/databases/$(database)/documents/routes/$(routeId));
    }

    function isPublishedRoute(routeId) {
      return routeDoc(routeId).data.isPublished == true;
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      // User docs are created by Cloud Functions only.
      allow create: if false;

      // Only allow user-owned profile updates from the client.
      allow update: if isOwner(userId)
        && unchanged('authUid')
        && unchanged('email')
        && unchanged('displayName')
        && unchanged('photoURL')
        && unchanged('accessTier')
        && unchanged('isNepalLocalEligible')
        && unchanged('activeJourneyId')
        && unchanged('createdAt')
        && unchanged('deletedAt');

      allow delete: if false;

      match /stepSnapshots/{localDate} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.localDate == localDate;

        allow delete: if false;
      }

      match /journeys/{journeyId} {
        allow read: if isOwner(userId);

        // Journeys are server-managed only.
        allow create, update: if false;
        allow delete: if false;

        match /ledger/{localDate} {
          allow read: if isOwner(userId);
          allow write, delete: if false;
        }
      }

      match /badges/{badgeId} {
        allow read: if isOwner(userId);
        allow write, delete: if false;
      }

      match /entitlements/{entitlementId} {
        allow read: if isOwner(userId);
        allow write, delete: if false;
      }

      match /events/{eventId} {
        allow read: if isOwner(userId);
        allow write, delete: if false;
      }

      match /usageCounters/{localDate} {
        allow read: if isOwner(userId);
        allow write, delete: if false;
      }
    }

    match /routes/{routeId} {
      allow read: if isSignedIn() && resource.data.isPublished == true;
      allow write, delete: if false;

      match /milestones/{milestoneId} {
        allow read: if isPublishedRoute(routeId);
        allow write, delete: if false;
      }
    }

    match /assetBundles/{assetBundleId} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }

    match /contentPacks/{contentPackId} {
      allow read: if isSignedIn()
        && routeDoc(resource.data.routeId).data.isPublished == true;
      allow write, delete: if false;
    }

    match /weatherCache/{cacheKey} {
      allow read: if false;
      allow write, delete: if false;
    }

    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }
  }
}
